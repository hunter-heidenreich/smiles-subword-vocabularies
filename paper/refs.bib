@misc{reddy2025diminishing-tokenization,
  author    = {Reddy, Varshini and Schmidt, Craig W. and Pinter, Yuval and Tanner, Chris},
  title     = {How Much is Enough? The Diminishing Returns of Tokenization Training Data},
  year      = {2025},
  eprint    = {2502.20273},
  archiveprefix = {arXiv},
  primaryclass  = {cs.CL},
  url       = {https://arxiv.org/abs/2502.20273},
  note      = {ICML 2025 Tokenization Workshop (TokShop)},
  annotation      = {Mechanistic argument that pre-tokenization sets the ceiling on tokenizer quality. Pretoken absorption (Fig.~7) is ``remarkably high across all algorithms, increasing with vocabulary size'' and essentially overlapping at 128K--256K (BPE/UnigramLM/WordPiece all $\sim$0.75--0.90 on NL; no large cross-algorithm gap, unlike chemistry small-$V$). Tokenizer quality plateaus around 150 GB English / 200 GB Russian.},
}

@inproceedings{schmidt2025boundless-bpe,
  author    = {Schmidt, Craig W. and Reddy, Varshini and Tanner, Chris and Pinter, Yuval},
  title     = {Boundless Byte Pair Encoding: Breaking the Pre-tokenization Barrier},
  booktitle = {Conference on Language Modeling (COLM)},
  year      = {2025},
  eprint    = {2504.00178},
  archiveprefix = {arXiv},
  primaryclass  = {cs.CL},
  url       = {https://arxiv.org/abs/2504.00178},
  annotation      = {BoundlessBPE: supermerges + PickyBPE deletions + BOUNDLESS\_PATTERN regex. 9--15\% bytes/tok gain over BPE/WordPiece/UnigramLM on English MiniPILE at V $\in\{$40,960; 65,536; 98,304; 131,072$\}$. No downstream LM training; intrinsic metrics only.},
}

