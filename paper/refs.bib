@inproceedings{wegmann2025tokenization,
  author    = {Wegmann, Anna and Nguyen, Dong and Jurgens, David},
  title     = {Tokenization is Sensitive to Language Variation},
  booktitle = {Findings of the Association for Computational Linguistics: ACL 2025},
  pages     = {10958--10983},
  year      = {2025},
  publisher = {Association for Computational Linguistics},
  doi       = {10.18653/v1/2025.findings-acl.572},
  url       = {https://aclanthology.org/2025.findings-acl.572/},
  annotation      = {Pre-trains BERT models varying tokenizer training corpus, pre-tokenizer, and vocabulary size. The pre-tokenizer has the greatest influence on downstream performance --- performance range largest for pre-tokenizer, then vocabulary size, then fitting corpus; using a pre-tokenizer beats using none. Introduces a logistic-regression estimator of downstream tokenizer impact, better-correlated than Renyi efficiency / corpus token count and, unlike them, comparable across vocabulary sizes.},
}


